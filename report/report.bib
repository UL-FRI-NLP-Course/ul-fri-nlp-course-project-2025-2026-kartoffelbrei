	doi = {10.1145/3655497.3655529},
	abstract = {This article examines the role of multimodal AI, specifically ChatGPT 4.0, in enhancing the travel experiences. It delves into multimodal interactions for more effective travel planning, offering personalized and comprehensive recommendations. A travel example is presented, showcasing ChatGPT's application throughout various travel stages. In the pre-travel phase, ChatGPT assists users in comparing destinations, planning activities, and even selecting transportation such as flights. Additionally, users can take advantage of its image recognition capabilities to provide additional information regarding objects encountered during travel, such as food, flora, and animals. Finally, in the post-travel phase, users can leverage ChatGPT's multimodal capabilities to create social media posts, location reviews, and other communication related to the travel experiences. While ChatGPT provides users with a transformative technology to enhance the travel experiences, issues such as bias mitigation and data privacy must be acknowledged and addressed in future research. However, incorporating multimodal AI, such as ChatGPT, shows the potential to revolutionize the tourism sector, providing personalized experiences and reshaping how travelers plan and conduct their journeys for enjoyable memories.},
	urldate = {2026-03-18},
	booktitle = {Proceedings of the 2024 {International} {Conference} on {Innovation} in {Artificial} {Intelligence}},
	publisher = {Association for Computing Machinery},
	author = {Zhang, Jianhao and Mills, Daniel J. and Huang, Hui-Wen},
